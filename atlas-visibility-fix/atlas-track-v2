#!/usr/bin/env bash
set -euo pipefail

# Atlas Visibility Tracking v2 - Consolidated Production Implementation
# Base: Sprint-b version (212 lines) with architect's schema + retry logic
# Fixes: All 21 bugs from doubt agent + senior dev review

DB_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/atlas"
DB_PATH="$DB_DIR/visibility.db"
LOCK_FILE="$DB_DIR/visibility.lock"
PRAGMAS="PRAGMA journal_mode=WAL; PRAGMA synchronous=NORMAL; PRAGMA foreign_keys=ON; PRAGMA busy_timeout=20000;"
SCHEMA_VERSION="1.0"
RETENTION_DAYS="${ATLAS_RETENTION_DAYS:-90}"

if ! [[ "$RETENTION_DAYS" =~ ^[0-9]+$ ]]; then
  echo "ERROR: ATLAS_RETENTION_DAYS must be a positive integer between 1 and 36500" >&2
  exit 1
fi
if (( RETENTION_DAYS < 1 || RETENTION_DAYS > 36500 )); then
  echo "ERROR: ATLAS_RETENTION_DAYS must be between 1 and 36500" >&2
  exit 1
fi

usage() {
  echo "Usage: $(basename "$0") \"description\" [-- command [args...]]" >&2
  exit 1
}

sqlite_run() {
  local sql="$1"
  sqlite3 -batch "$DB_PATH" "$PRAGMAS $sql"
}

sqlite_quote() {
  local value="$1"
  local escaped=${value//\'/''}
  sqlite3 -batch "$DB_PATH" "SELECT quote('$escaped');"
}

validate_uuid() {
  [[ "$1" =~ ^[a-f0-9]{8}-[a-f0-9]{4}-4[a-f0-9]{3}-[89ab][a-f0-9]{3}-[a-f0-9]{12}$ ]]
}

gen_uuid() {
  if command -v uuidgen >/dev/null 2>&1; then
    tr 'A-Z' 'a-z' <<<"$(uuidgen)"
  else
    python3 - <<'PY'
import uuid
print(uuid.uuid4())
PY
  fi
}

task_id_exists() {
  local candidate="$1"
  local candidate_q
  candidate_q=$(sqlite_quote "$candidate")
  # Use flock for safe concurrent read
  (
    exec 9>"$LOCK_FILE"
    flock -w 5 9 || exit 1
    sqlite_run "SELECT 1 FROM entries WHERE task_id = ${candidate_q} LIMIT 1;" | grep -q 1
  )
}

generate_task_id() {
  local candidate
  local max_attempts=100
  local attempt=0

  while [ $attempt -lt $max_attempts ]; do
    candidate=$(gen_uuid)
    if validate_uuid "$candidate" && ! task_id_exists "$candidate"; then
      echo "$candidate"
      return 0
    fi
    ((attempt++))
  done

  echo "ERROR: Failed to generate unique task ID after $max_attempts attempts" >&2
  return 1
}

begin_transaction() {
  sqlite_run "BEGIN IMMEDIATE;"
  trap 'sqlite_run "ROLLBACK;"' ERR
}

commit_transaction() {
  trap - ERR
  sqlite_run "COMMIT;"
}

run_txn_with_retry() {
  local sql="$1"
  local max_attempts=7
  local attempt=1
  local delay=1

  while [ $attempt -le $max_attempts ]; do
    if sqlite_run "$sql"; then
      return 0
    fi

    if [ $attempt -lt $max_attempts ]; then
      echo "[WARNING] Database locked, retry ${attempt}/${max_attempts} in ${delay}s..." >&2
      sleep $delay
      delay=$((delay * 2))
    fi
    ((attempt++))
  done
  echo "ERROR: Database operation failed after ${max_attempts} attempts." >&2
  return 1
}

run_write_txn_with_retry() {
  local sql="$1"
  local max_attempts=7
  local attempt=1
  local delay=1

  while [ $attempt -le $max_attempts ]; do
    # Use flock to serialize database writes
    if (
      exec 9>"$LOCK_FILE"
      flock -w 10 9 || exit 1
      sqlite_run "BEGIN IMMEDIATE; $sql; COMMIT;"
    ); then
      return 0
    fi

    if [ $attempt -lt $max_attempts ]; then
      echo "[WARNING] Database locked, retry ${attempt}/${max_attempts} in ${delay}s..." >&2
      sleep $delay
      delay=$((delay * 2))
    fi
    ((attempt++))
  done
  echo "ERROR: Database write operation failed after ${max_attempts} attempts." >&2
  return 1
}

ensure_db() {
  mkdir -p "$DB_DIR"

  # Initialize schema if needed (CREATE TABLE IF NOT EXISTS is safe for concurrency)
  if [ -f "src/schema.sql" ]; then
    sqlite3 -batch "$DB_PATH" < src/schema.sql 2>/dev/null || true
  else
    # Fallback inline schema - safe for concurrent calls
    sqlite_run "
      CREATE TABLE IF NOT EXISTS entries (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        task_id TEXT UNIQUE NOT NULL,
        description TEXT NOT NULL,
        command TEXT,
        exit_code INTEGER,
        duration_seconds INTEGER,
        status TEXT CHECK(status IN ('logged','running','completed','failed')),
        stdout BLOB,
        stderr BLOB,
        created_at TEXT DEFAULT (datetime('now')),
        updated_at TEXT DEFAULT (datetime('now'))
      );

      CREATE INDEX IF NOT EXISTS idx_entries_created_at ON entries(created_at DESC);
      CREATE INDEX IF NOT EXISTS idx_entries_status ON entries(status);
      CREATE INDEX IF NOT EXISTS idx_entries_task_id ON entries(task_id);

      CREATE TABLE IF NOT EXISTS metadata (
        key TEXT PRIMARY KEY,
        value TEXT NOT NULL
      );

      CREATE TRIGGER IF NOT EXISTS entries_updated_at_tr
      AFTER UPDATE ON entries
      BEGIN
        UPDATE entries SET updated_at = datetime('now') WHERE id = NEW.id;
      END;
    " 2>/dev/null || true
  fi

  # Update retention trigger (idempotent)
  sqlite_run "DROP TRIGGER IF EXISTS cleanup_old_entries;" 2>/dev/null || true
  sqlite_run "
    CREATE TRIGGER IF NOT EXISTS cleanup_old_entries
    AFTER INSERT ON entries
    BEGIN
      DELETE FROM entries
        WHERE created_at < datetime(
          'now',
          '-' || COALESCE((SELECT value FROM metadata WHERE key = 'retention_days'), '90') || ' days'
        );
    END;
  " 2>/dev/null || true

  # Set/update schema version and retention in metadata (use flock for this critical section)
  local schema_q retention_q
  schema_q=$(sqlite_quote "$SCHEMA_VERSION")
  retention_q=$(sqlite_quote "$RETENTION_DAYS")

  local current_version
  current_version=$(
    (
      exec 9>"$LOCK_FILE"
      flock -w 10 9 || exit 1
      sqlite3 -batch "$DB_PATH" <<SQL 2>/dev/null
$PRAGMAS
SELECT value FROM metadata WHERE key = 'schema_version';
SQL
    ) 2>/dev/null | tail -n 1 | tr -d '\r'
  )

  # Initialize metadata if needed
  if [[ -z "$current_version" ]]; then
    (
      exec 9>"$LOCK_FILE"
      flock -w 10 9 || exit 1
      sqlite3 -batch "$DB_PATH" <<SQL 2>/dev/null
$PRAGMAS
BEGIN IMMEDIATE;
INSERT OR IGNORE INTO metadata(key, value) VALUES ('schema_version', $schema_q);
INSERT OR IGNORE INTO metadata(key, value) VALUES ('retention_days', $retention_q);
COMMIT;
SQL
    ) 2>/dev/null || true
    current_version="$SCHEMA_VERSION"
  fi

  # Strict schema version check for safety
  if [[ "$current_version" != "$SCHEMA_VERSION" ]]; then
    echo "ERROR: Schema version mismatch - database is '$current_version' but this script requires '$SCHEMA_VERSION'." >&2
    echo "To migrate: Back up $DB_PATH, then remove or rename it before running this version." >&2
    exit 1
  fi
}

log_initial() {
  local task_id="$1"
  local description="$2"
  local command="$3"
  local desc_q cmd_q
  desc_q=$(sqlite_quote "$description")
  if [[ -n "$command" ]]; then
    cmd_q=$(sqlite_quote "$command")
  else
    cmd_q="NULL"
  fi

  local sql="INSERT INTO entries(task_id, description, command, status) VALUES ($task_id, $desc_q, $cmd_q, 'logged');"
  run_write_txn_with_retry "$sql"
}

mark_running() {
  local task_id_q="$1"
  run_write_txn_with_retry "UPDATE entries SET status='running', updated_at=datetime('now') WHERE task_id = $task_id_q;"
}

finalize_task() {
  local task_id_q="$1"
  local exit_code="$2"
  local duration="$3"
  local stdout_content="$4"
  local stderr_content="$5"
  local status="completed"
  [[ "$exit_code" -ne 0 ]] && status="failed"

  local stdout_q stderr_q
  stdout_q=$(sqlite_quote "$stdout_content")
  stderr_q=$(sqlite_quote "$stderr_content")

  local sql="
    UPDATE entries
      SET status='$status',
          exit_code=$exit_code,
          duration_seconds=$duration,
          stdout=$stdout_q,
          stderr=$stderr_q,
          updated_at=datetime('now')
      WHERE task_id = $task_id_q;
  "
  run_write_txn_with_retry "$sql"
}

finalize_task_from_files() {
  local task_id_q="$1"
  local exit_code="$2"
  local duration="$3"
  local stdout_file="$4"
  local stderr_file="$5"
  local status="completed"
  [[ "$exit_code" -ne 0 ]] && status="failed"

  local stdout_path_q stderr_path_q
  stdout_path_q=$(sqlite_quote "$stdout_file")
  stderr_path_q=$(sqlite_quote "$stderr_file")

  local sql="
    UPDATE entries
      SET status='$status',
          exit_code=$exit_code,
          duration_seconds=$duration,
          stdout=readfile($stdout_path_q),
          stderr=readfile($stderr_path_q),
          updated_at=datetime('now')
      WHERE task_id = $task_id_q;
  "
  run_write_txn_with_retry "$sql"
}

main() {
  if [[ $# -lt 1 ]]; then
    usage
  fi

  local description="$1"
  shift || true

  local cmd=()
  if [[ $# -gt 0 ]]; then
    if [[ "$1" != "--" ]]; then
      echo "If providing a command, place it after --" >&2
      exit 1
    fi
    shift
    cmd=("$@")
  fi

  ensure_db

  local task_id
  task_id=$(generate_task_id)
  local task_id_q
  task_id_q=$(sqlite_quote "$task_id")

  local command_str=""
  if [[ ${#cmd[@]} -gt 0 ]]; then
    printf -v command_str '%q ' "${cmd[@]}"
    command_str=${command_str%% }
  fi

  log_initial "$task_id_q" "$description" "$command_str"
  echo "✓ Logged task $task_id: $description"

  if [[ ${#cmd[@]} -eq 0 ]]; then
    exit 0
  fi

  mark_running "$task_id_q"

  local stdout_file stderr_file
  stdout_file=$(mktemp)
  stderr_file=$(mktemp)
  trap 'rm -f "$stdout_file" "$stderr_file"' EXIT

  local start_ts
  start_ts=$(date +%s)
  local exit_code
  set +e
  "${cmd[@]}" >"$stdout_file" 2>"$stderr_file"
  exit_code=$?
  set -e
  local end_ts
  end_ts=$(date +%s)
  local duration=$(( end_ts - start_ts ))

  finalize_task_from_files "$task_id_q" "$exit_code" "$duration" "$stdout_file" "$stderr_file"

  rm -f "$stdout_file" "$stderr_file"
  trap - EXIT

  if [[ "$exit_code" -eq 0 ]]; then
    echo "✓ Task $task_id completed in ${duration}s"
  else
    echo "✗ Task $task_id failed with exit code $exit_code after ${duration}s" >&2
    exit "$exit_code"
  fi
}

main "$@"
