# Agent League Production Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# CONTROL PLANE CONFIGURATION
# =============================================================================
CONTROL_PLANE_HOST=localhost
CONTROL_PLANE_PORT=8080
CONTROL_PLANE_PROTOCOL=http

# API Keys for Control Plane (if authentication is enabled)
CONTROL_PLANE_API_KEY=

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Redis TLS (for remote Redis)
REDIS_TLS_ENABLED=false
REDIS_TLS_CERT_PATH=

# =============================================================================
# AGENT CONFIGURATION
# =============================================================================
# Maximum number of agents to run in parallel
MAX_CONCURRENT_AGENTS=5

# Agent timeout in seconds
AGENT_TIMEOUT=300

# Agent polling interval (milliseconds)
AGENT_POLL_INTERVAL=1000

# Agent result retention (days)
AGENT_RESULT_RETENTION_DAYS=7

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log format: json, text
LOG_FORMAT=json

# Enable Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# =============================================================================
# NOTIFICATIONS
# =============================================================================
# Enable failure notifications
NOTIFICATIONS_ENABLED=false

# Webhook URL for notifications
NOTIFICATION_WEBHOOK_URL=

# Email for alerts
ALERT_EMAIL=

# =============================================================================
# DEVELOPMENT/TESTING
# =============================================================================
# Enable debug mode (verbose logging, stack traces)
DEBUG=false

# Mock mode (run agents without actual execution)
MOCK_MODE=false

# =============================================================================
# DOCKER CONFIGURATION (if using Docker)
# =============================================================================
DOCKER_IMAGE_NAME=agent-league
DOCKER_IMAGE_TAG=latest
DOCKER_CONTAINER_NAME=agent-league

# Docker network
DOCKER_NETWORK=agent-league-network

# =============================================================================
# SECURITY
# =============================================================================
# JWT Secret for agent authentication
JWT_SECRET=change-this-in-production

# Allowed origins for CORS
CORS_ALLOWED_ORIGINS=*

# Rate limiting (requests per minute)
RATE_LIMIT_RPM=60

# =============================================================================
# BACKUP & RECOVERY
# =============================================================================
# Backup directory
BACKUP_DIR=/var/backups/agent-league

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Auto-backup interval (hours, 0 to disable)
AUTO_BACKUP_INTERVAL_HOURS=24
