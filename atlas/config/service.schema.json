{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas.service.schema.json",
  "title": "Atlas Service",
  "type": "object",
  "required": ["id", "name", "endpoints"],
  "properties": {
    "id": {"type": "string"},
    "name": {"type": "string"},
    "endpoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url", "protocol"],
        "properties": {
          "url": {"type": "string"},
          "protocol": {"enum": ["http", "https", "grpc", "tcp"]},
          "auth": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "dependencies": {"type": "array", "items": {"type": "string"}},
    "health_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {"enum": ["http", "tcp", "command"]},
          "interval_sec": {"type": "integer", "minimum": 5},
          "target": {"type": "string"}
        },
        "required": ["type", "interval_sec", "target"],
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
