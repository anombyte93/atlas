{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas.agent.schema.json",
  "title": "Atlas Agent",
  "type": "object",
  "required": ["schema_version", "id", "device_id", "version", "control_plane_url", "heartbeat_interval_sec"],
  "properties": {
    "schema_version": {"type": "string"},
    "id": {"type": "string", "minLength": 8},
    "device_id": {"type": "string", "minLength": 8},
    "version": {"type": "string"},
    "control_plane_url": {"type": "string", "format": "uri"},
    "api_token": {"type": "string"},
    "heartbeat_interval_sec": {"type": "integer", "minimum": 5},
    "task_poll_interval_sec": {"type": "integer", "minimum": 5},
    "world_repo_path": {"type": "string"},
    "allow_all_commands": {"type": "boolean"},
    "allowed_commands": {"type": "array", "items": {"type": "string"}},
    "lease_renew_seconds": {"type": "integer", "minimum": 5},
    "permissions": {
      "type": "object",
      "properties": {
        "read_only": {"type": "boolean"},
        "allowed_paths": {"type": "array", "items": {"type": "string"}}
      },
      "required": ["read_only"]
    },
    "resources": {
      "type": "object",
      "properties": {
        "cpu_limit": {"type": "number", "minimum": 0},
        "memory_limit_mb": {"type": "integer", "minimum": 128}
      }
    },
    "tags": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
