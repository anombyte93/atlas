{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "atlas.graph.schema.json",
  "title": "Atlas Context Graph Schemas",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": {"type": "string"},
          "type": {"enum": ["run", "file", "device", "model"]},
          "attributes": {"type": "object", "additionalProperties": true}
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source", "target", "type"],
        "properties": {
          "source": {"type": "string"},
          "target": {"type": "string"},
          "type": {"enum": ["used_in", "produced_by", "preceded_by"]},
          "attributes": {"type": "object", "additionalProperties": true}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
