{
  "schema_version": "1.0.0",
  "id": "policy-readonly",
  "type": "rbac",
  "scope": "agents",
  "rules": [
    {"effect": "allow", "action": "read", "resource": "logs"},
    {"effect": "deny", "action": "write", "resource": "filesystem"}
  ],
  "constraints": {
    "max_task_runtime_sec": 900
  }
}
